# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.pyright/
.mypy_cache/

# uv
uv.lock.bak

# Node
node_modules/
dist/
.vite/

# Env files
.env
.env.local
.env.*.local
!.env.example
!.env.*.example

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp

# Docker
.dockerignore.bak

# Codegen output — regenerated by `just generate_types`. .gitkeep preserves
# the directory so a fresh clone still has somewhere for the generators to
# write to.
generated/*
!generated/.gitkeep
!generated/README.md
frontend/src/generated/**
!frontend/src/generated/.gitkeep

# Logs
*.log
